  background-color: #0d1b2a;
  color: #a0aec0;
  text-align: center;
  padding: 1.2rem 1rem;
  font-family: 'Lato', sans-serif;
  font-size: 0.9rem;
  margin-top: 3rem;
  border-top: 3px solid #1b2a6b;
}
.site-footer a {
  color: #90a8e8;
  text-decoration: none;
}
.site-footer a:hover {
  color: #ffffff;
}
</style>

<footer class="site-footer">
